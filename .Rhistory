install.packages("ggplot2")
fx_data <- data.frame(
Pair = c("EUR/USD", "GBP/USD", "JPY/USD", "EUR/USD", "GBP/USD", "JPY/USD"),
Day = c(1, 1, 1, 2, 2, 2),
Open_Rate = c(1.08, 1.26, 0.0068, 1.09, 1.25, 0.0069),
Close_Rate = c(1.09, 1.27, 0.0067, 1.08, 1.26, 0.0070),
Volume = c(1000, 850, 1200, 1100, 900, 1300)
)
# Load the package
library(ggplot2)
# Building the plot layer by layer
ggplot(data = fx_data, aes(x = Open_Rate, y = Close_Rate, color = Pair)) +
geom_point(size = 3) +                            # Adds the scatter plot dots
labs(title = "FX Open vs Close Rates",            # Adds titles and labels
x = "Opening Price",
y = "Closing Price") +
theme_minimal()                                   # Gives it a clean, professional look
ggplot(data = fx_data, aes(x= Pair, y=Volume)) +
geom_col() +
labs(title = "FX Pair vs Volume") + theme_minimal()
install.packages("tidyr")
library(tidyr)
library(dplyr)
# 1. The Wide Data (Typical finance download format)
wide_prices <- data.frame(
Date = c("2024-01-01", "2024-01-02"),
AAPL = c(180.5, 181.2),
MSFT = c(330.1, 332.5)
)
# 2. Making it Long
long_prices <- wide_prices %>%
pivot_longer(
cols = c(AAPL, MSFT),      # The columns we want to melt down
names_to = "Ticker",       # The new column name for the column headers
values_to = "Price"        # The new column name for the actual numbers
)
print(long_prices)
bond_yields_wide <- data.frame(
Date = c("2024-03-01", "2024-03-02"),
Yield_2Yr = c(4.55, 4.58),
Yield_10Yr = c(4.20, 4.25),
Yield_30Yr = c(4.35, 4.38)
)
